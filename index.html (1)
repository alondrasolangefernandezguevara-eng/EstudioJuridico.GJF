    <style>
        :root {
            --bordo: #800020;
            --bordo-hover: #5a0016;
            --dorado: #c5a059;
        }
        body {
            font-family: 'Montserrat', sans-serif;
            scroll-behavior: smooth;
            background-color: #ffffff;
        }
        h1, h2, h3, .serif {
            font-family: 'Playfair Display', serif;
        }
        
        /* Efecto Hero */
        .hero-section {
            position: relative;
            min-height: 90vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            padding-top: 80px;
        }
        .themis-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            opacity: 0.15;
            filter: blur(8px);
            background: url('https://images.unsplash.com/photo-1589829545856-d10d557cf95f?auto=format&fit=crop&q=80&w=1920') center/cover no-repeat;
            animation: slowZoom 30s infinite alternate linear;
        }
        @keyframes slowZoom {
            from { transform: scale(1); }
            to { transform: scale(1.2); }
        }

        /* Menu Lateral */
        .side-menu {
            position: fixed;
            top: 0;
            right: -100%;
            width: 80%;
            max-width: 320px;
            height: 100%;
            background: var(--bordo);
            z-index: 1000;
            transition: 0.5s cubic-bezier(0.77, 0.2, 0.05, 1);
            box-shadow: -10px 0 30px rgba(0,0,0,0.5);
        }
        .side-menu.active { right: 0; }

        /* Tarjetas de Áreas Practicadas - Uniformidad */
        .area-card {
            border: 1px solid #e5e7eb;
            transition: all 0.3s ease;
            cursor: pointer;
            height: 100%;
            display: flex;
            flex-direction: column;
            background: #fff;
        }
        .area-card:hover {
            border-color: var(--bordo);
            box-shadow: 0 10px 20px rgba(128, 0, 32, 0.1);
            transform: translateY(-5px);
        }
        .area-details {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.5s ease;
        }
        .area-card.active .area-details {
            max-height: 800px; /* Suficiente para el contenido */
        }
        .area-card.active .chevron-icon {
            transform: rotate(180deg);
        }

        /* Botón WhatsApp Flotante */
        .whatsapp-btn {
            position: fixed;
            bottom: 25px;
            right: 25px;
            background-color: #25d366;
            color: white;
            width: 65px;
            height: 65px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 35px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            z-index: 998;
            transition: transform 0.3s;
        }
        .whatsapp-btn:hover { transform: scale(1.1); }

        .image-frame {
            position: relative;
            padding: 12px;
            background: white;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            border-radius: 2px;
            border: 1px solid #eee;
        }
    </style>
